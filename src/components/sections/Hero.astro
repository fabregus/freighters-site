---
const {
  titleLeft = "Freighters.",
  titleRight = "Moving Forward",
  videoSrc = "/video/home_hero.mp4",
} = Astro.props;
---

<section class="relative">
  <!-- Background -->
  <section class="relative">
    <!-- Full-bleed media -->
    <div class="relative h-128 w-full overflow-hidden md:h-160">
      <video
        class="h-full w-full object-cover contrast-[1.05] saturate-[0.9]"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src={videoSrc} type="video/mp4" />
      </video>

      <!-- overlays -->
      <!-- blue / teal overlay -->
      <div
        class="absolute inset-0 bg-linear-to-b from-[#061A2A]/70 via-[#0b2d45]/40 to-transparent"
      >
      </div>

      <!-- subtle color tint -->
      <div class="absolute inset-0 bg-[#0a3a5a]/20 mix-blend-multiply"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_40%,rgba(0,0,0,0.35)_100%)]"
      >
      </div>

      <!-- Headline -->
      <div class="pointer-events-none absolute inset-0 z-10 flex items-center">
        <div class="w-full px-4 md:px-8">
          <div
            class="hero-marquee pb-[0.12em] text-5xl leading-[1.15] font-light tracking-[0.03em] md:text-[11vw] md:leading-[1.15] md:tracking-[0.04em]"
          >
            <div class="hero-marquee-content">
              <div class="hero-marquee-track">
                <span class="hero-marquee-item">
                  <span class="text-[#F5B400]">{titleLeft}</span>{" "}
                  <span class="text-white">{titleRight}</span>
                </span>
                <span class="hero-marquee-item">
                  <span class="text-[#F5B400]">{titleLeft}</span>{" "}
                  <span class="text-white">{titleRight}</span>
                </span>
                <span class="hero-marquee-item">
                  <span class="text-[#F5B400]">{titleLeft}</span>{" "}
                  <span class="text-white">{titleRight}</span>
                </span>
              </div>
              <div class="hero-marquee-track" aria-hidden="true">
                <span class="hero-marquee-item">
                  <span class="text-[#F5B400]">{titleLeft}</span>{" "}
                  <span class="text-white">{titleRight}</span>
                </span>
                <span class="hero-marquee-item">
                  <span class="text-[#F5B400]">{titleLeft}</span>{" "}
                  <span class="text-white">{titleRight}</span>
                </span>
                <span class="hero-marquee-item">
                  <span class="text-[#F5B400]">{titleLeft}</span>{" "}
                  <span class="text-white">{titleRight}</span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Header slot -->
    <slot />
  </section>
</section>

<style>
  .hero-marquee {
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
  }

  .hero-marquee-content {
    display: flex;
    width: max-content;
    animation: hero-marquee-left 36s linear infinite;
  }

  .hero-marquee-track {
    display: flex;
    flex-shrink: 0;
  }

  .hero-marquee-item {
    white-space: nowrap;
    margin-right: 4rem;
  }

  @keyframes hero-marquee-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-marquee-content {
      animation: none;
    }
  }
</style>
