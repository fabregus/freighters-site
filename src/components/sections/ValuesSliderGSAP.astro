---
const slides = [
  {
    n: "1",
    title: "RELIABILITY",
    body:
      "We ensure every shipment arrives safely,\non schedule, with consistent service you can always trust.",
    bg: "#061A2A",
  },
  {
    n: "2",
    title: "SMART\nSOLUTIONS",
    body:
      "We design efficient logistics strategies that reduce\ncosts, improve speed, and simplify global trade.",
    bg: "#F5B400",
  },
  {
    n: "3",
    title: "PARTNERSHIP",
    body:
      "We work closely with clients, understanding their goals\nto deliver long-term logistics success together.",
    bg: "#2E6671",
  },
];
---

<section id="values" class="bg-white">
  <div class="container-site py-10">
    <h2 class="text-[40px] font-light text-black">VALUES</h2>
  </div>

  <!-- Wrapper: παίρνει ύψος N*100vh από το script -->
  <div id="values-wrap">
    <!-- Pinned viewport -->
    <div id="values-pin" class="relative h-screen overflow-hidden">
      <div class="relative h-full w-full">
        {slides.map((s, i) => (
          <article
            class="values-panel absolute inset-0 h-full w-full"
            style={`background:${s.bg}; transform: translateY(${i * 100}%);`}
          >
            <!-- huge number -->
            <div class="absolute left-10 top-10 text-[140px] leading-none font-light text-white/95">
              {s.n}
            </div>

            <!-- huge title -->
            <div class="absolute right-10 top-10 text-right text-white">
              <div class="whitespace-pre-line text-[88px] leading-[0.9] font-light tracking-[0.06em]">
                {s.title}
              </div>
            </div>

            <!-- centered body -->
            <div class="absolute inset-0 flex items-center justify-center px-6">
              <p class="max-w-xl text-center whitespace-pre-line text-[18px] leading-7 text-white/90">
                {s.body}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Astro-bundled script (Vite bundling) -->
  <script>
    import "../../scripts/values-gsap.js";
  </script>
</section>