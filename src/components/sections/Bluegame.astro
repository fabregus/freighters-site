---
const items = [
  {
    title: "Control Tower",
    description:
      "A single planning environment connecting orders, shipments and operational flows.",
  },
  {
    title: "Real-Time Visibility",
    description: "Live status and auto notifications across every movement.",
  },
  {
    title: "Flow-Based Planning",
    description:
      "Dynamic routing and prioritization based on urgency, capacity, and operational constraints.",
  },
  {
    title: "Full Data Continuity",
    description:
      "One source of information across logistics, warehouse, port, and airport operations.",
  },
  {
    title: "AI Decision Support",
    description:
      "Auto-suggestions that reduce delays, improve accuracy, and stabilize execution.",
  },
  {
    title: "High-Intensity Operations",
    description:
      "Designed to support aviation, hospitality, and maritime logistics with the same precision.",
  },
];
---

<section class="bluegame-bg">
  <div class="container-site py-24">
    <div class="w-full overflow-hidden text-center">
      <a
        class="button-primary"
        href="https://portal.bluegameitsolutions.com/login"
        target="_blank"
        rel="noopener"
      >
        <img
          src="/images/bluegame-logo.png"
          alt="Bluegame"
          class="bluegame-logo"
          loading="lazy"
          decoding="async"
        />
        <span class="login-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path
              d="M14 4H8.8C7.11984 4 6.27976 4 5.63803 4.32698C5.07354 4.6146 4.6146 5.07354 4.32698 5.63803C4 6.27976 4 7.11984 4 8.8V15.2C4 16.8802 4 17.7202 4.32698 18.362C4.6146 18.9265 5.07354 19.3854 5.63803 19.673C6.27976 20 7.11984 20 8.8 20H14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M10 12H20M20 12L17 9M20 12L17 15"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>

    <div class="mx-auto mt-14 max-w-6xl text-center">
      <div class="rounded-2xl bg-white/78 px-6 py-8 backdrop-blur-[2px]">
        <h2 class="text-[28px] sm:text-[34px] leading-[1.05] font-light tracking-tight text-black">
          Bluegame Platform - Real-Time, End-to-End Planning
        </h2>
        <p class="mt-3 text-black/85">
          We provide digital account management through our customer portal,
          which allows for speeding up decision making.
        </p>
      </div>
    </div>

    <div
      class="mx-auto mt-12 grid max-w-6xl gap-6 md:grid-cols-2 lg:grid-cols-3"
    >
      {
        items.map((item) => (
          <article class="rounded-2xl border border-[#0b2d45]/15 bg-white/78 p-6 backdrop-blur-[2px]">
            <h3 class="text-[20px] leading-tight font-semibold text-[#0b2d45]">
              {item.title}
            </h3>
            <p class="mt-4 text-[16px] leading-7 text-black/85">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .button-primary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #172654 0%, #121f48 100%);
    padding: 16px 36px;
    justify-content: center;
    text-decoration: none;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    cursor: pointer;
    transition:
      box-shadow 180ms ease,
      filter 180ms ease;
    box-shadow:
      0 12px 34px rgba(8, 16, 44, 0.28),
      inset 0 -2px 0 rgba(7, 15, 40, 0.65),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    width: 200px;
    z-index: 0;
  }

  .button-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      110deg,
      transparent 0%,
      transparent 35%,
      rgba(255, 255, 255, 0.28) 50%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-130%);
    opacity: 0;
    transition:
      transform 620ms ease,
      opacity 620ms ease;
    pointer-events: none;
  }

  .button-primary::after {
    content: "";
    position: absolute;
    inset: -30% -10%;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at center,
      rgba(138, 181, 255, 0.38) 0%,
      rgba(138, 181, 255, 0) 65%
    );
    opacity: 0;
    transform: scale(0.85);
    transition:
      opacity 260ms ease,
      transform 260ms ease;
    pointer-events: none;
  }

  .button-primary:hover {
    box-shadow:
      0 16px 34px rgba(9, 23, 66, 0.4),
      inset 0 -2px 0 rgba(7, 15, 40, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    filter: brightness(1.08);
  }

  .button-primary:hover::before {
    transform: translateX(130%);
    opacity: 1;
  }

  .button-primary:hover::after {
    opacity: 0.55;
    transform: scale(1);
  }

  .button-primary:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.25);
  }

  .button-primary:disabled,
  .button-primary[aria-disabled="true"] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  .bluegame-logo {
    position: relative;
    z-index: 2;
    width: 96px;
    height: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .login-icon {
    position: relative;
    z-index: 2;
    color: #ffffff;
  }

  .login-icon svg {
    width: 1.6rem;
    height: 1.6rem;
    display: block;
    transition: transform 200ms ease;
  }

  .button-primary:hover .login-icon svg {
    transform: translateX(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .button-primary::before,
    .button-primary::after,
    .button-primary {
      animation: none !important;
      transition: none !important;
      box-shadow: none !important;
    }

    .button-primary:hover .login-icon svg {
      transform: none;
    }
  }

  @media (prefers-contrast: more) {
    .button-primary {
      background: #0e152c !important;
      color: #ffffff !important;
    }
  }
</style>
