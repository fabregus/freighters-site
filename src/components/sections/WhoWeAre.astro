---
const title = "WHO WE ARE";

const p1 =
  "Freighters is a modern trading and logistics company built to support businesses in a fast-moving global market.";

const p2 =
  "With deep industry knowledge and a network of trusted partners, we provide smart freight solutions that combine reliability, flexibility, and transparency.";

const image = "/images/who-we-are.png";
---

<section id="about" class="bg-white">
  <div class="container-site relative py-24">
    <!-- TOP YELLOW LINE -->
    <div class="absolute top-0 left-0 h-1.5 w-2/5 bg-primary"></div>

    <div class="grid items-center gap-16 lg:grid-cols-12">
      <!-- TEXT COLUMN -->
      <div class="lg:col-span-6">
        <div class="mx-auto max-w-130 text-center">
          <h2 class="text-[36px] tracking-[0.18em] text-black">
            {title}
          </h2>

          <div class="mt-12 space-y-10 text-[15px] leading-7 text-black/60">
            <p>{p1}</p>
            <p>{p2}</p>
          </div>
        </div>
      </div>

      <!-- IMAGE COLUMN -->
      <div class="lg:col-span-6">
        <div class="ml-auto max-w-160">
          <div class="aspect-4/5 w-full overflow-hidden">
            <img
              src={image}
              alt="Freighters warehouse"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- BOTTOM YELLOW LINE -->
    <div class="absolute bottom-0 right-0 h-1.5 w-1/3 bg-primary"></div>
  </div>
</section>
