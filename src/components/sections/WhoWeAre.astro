---
const {
  title = "WHO WE ARE",
  text = "At Freighters, we combine advanced logistics planning with a strong international network to deliver reliable freight solutions across borders. Every shipment is handled with care, transparency, and speed.",
  paragraphs,
  image = "/images/who-we-are.png",
  imageAlt = "Freighters warehouse",
} = Astro.props;

const contentParagraphs = paragraphs ?? [text];
---

<section id="about" class="bg-white font-medium">
  <div class="container-site relative py-24">
    <div class="grid items-center gap-16 lg:grid-cols-12">
      <!-- TEXT COLUMN -->
      <div class="lg:col-span-6">
        <div class="mx-auto max-w-130 text-center">
          <h2 class="text-[36px] tracking-[0.18em] text-black">
            {title}
          </h2>

          <div class="mt-12 space-y-10 text-[15px] leading-7 text-black/60">
            {contentParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </div>

      <!-- IMAGE COLUMN -->
      <div class="lg:col-span-6">
        <div class="ml-auto max-w-160">
          <div class="aspect-square w-full overflow-hidden">
            <img
              src={image}
              alt={imageAlt}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
