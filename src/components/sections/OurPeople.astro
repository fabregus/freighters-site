---
/**
 * Our People section (About Us)
 * Usage:
 * <OurPeople image={ourPeopleImg} />
 */

type Props = {
  image: any; // Astro image import (e.g. import img from "...";)
  title?: string;
  lead?: string;
  body?: string;
  bgClass?: string;
};

const {
  image,
  title = "OUR PEOPLE",
  lead = "Freighters is a modern trading and logistics company built to support businesses in a fast-moving global market.",
  body = "Our people are at the heart of everything we do, driving the seamless flow of global trade. We foster a supportive and inclusive workplace that values diverse perspectives and invests in continuous development, empowering our teams to perform at their best.",
  bgClass = "bg-neutral-100",
} = Astro.props;
---

<section class={`w-full ${bgClass} py-16 sm:py-20`}>
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
      <!-- Image -->
      <div>
        <img
          src={image}
          alt="Freighters team"
          class="w-full h-80 sm:h-105 lg:h-150 object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Content -->
      <div class="text-center max-w-xl mx-auto lg:mx-0">
        <h2
          class="text-2xl sm:text-3xl lg:text-4xl font-light uppercase text-neutral-900 mt-16"
        >
          {title}
        </h2>

        <div class="mt-8 space-y-6 text-neutral-700">
          <p class="text-base sm:text-lg leading-relaxed font-medium">{lead}</p>
          <p class="text-base sm:text-lg leading-relaxed font-medium">{body}</p>
        </div>
      </div>
    </div>
  </div>
</section>
