---
const { text = "At Freighters, we go beyond transportation" } = Astro.props;
---

<section class="bg-white text-center">
  <div class="container-site py-5 mb-8">
    <p
      class="mx-auto max-w-4xl font-light text-black
               text-[36px] leading-[1.12]
               md:text-[56px] md:leading-[1.04]"
    >
      {text}
    </p>
  </div>
</section>
