---
const { text = "At Freighters, we go beyond transportation." } = Astro.props;
---

<section id="bluegame" class="bg-white">
  <div class="container-site relative py-28 mb-8">
    <div class="absolute top-0 left-0 h-1.5 w-2/5 bg-primary"></div>

    <h2
      class="mx-auto max-w-5xl text-center font-light text-black
             text-[52px] leading-[1.05]
             md:text-[80px] md:leading-none
             lg:text-[96px] lg:leading-[0.98]"
    >
      {text}
    </h2>

    <div class="absolute bottom-0 right-0 h-1.5 w-2/5 bg-primary"></div>
  </div>
</section>
