---
const {
  title = "VALUES",
  slides = [
    {
      number: "1",
      heading: "RELIABILITY",
      body: "We ensure every shipment arrives safely, on schedule,\nwith consistent service you can always trust.",
      bg: "#061A2A",
      fg: "#FFFFFF",
    },
    {
      number: "2",
      heading: "SMART\nSOLUTIONS",
      body: "We design efficient logistics strategies that reduce\ncosts, improve speed, and simplify global trade.",
      bg: "#F5B400",
      fg: "#FFFFFF",
    },
    {
      number: "3",
      heading: "PARTNERSHIP",
      body: "We work closely with clients, understanding their goals\nto deliver long-term logistics success together.",
      bg: "#2E6671",
      fg: "#FFFFFF",
    },
  ],
} = Astro.props;

// helper για id
const ids = slides.map((_, i) => `value-${i + 1}`);
---

<section id="values" class="bg-white">
  <div class="container-site py-10">
    <h2 class="text-[40px] tracking-tight font-light text-black">VALUES</h2>
  </div>

  <!-- Scroll-snap slider -->
    <div
    id="values-slider"
    class="relative h-screen overflow-y-auto snap-y snap-mandatory scroll-smooth overscroll-y-contain"
    style="-webkit-overflow-scrolling: touch;"
    aria-label="Values slider"
    >
    {slides.map((s, idx) => (
      <article
        id={ids[idx]}
        class="relative h-screen snap-start"
        style={`background:${s.bg}; color:${s.fg};`}
      >
        <!-- huge number -->
        <div class="absolute left-10 top-10 text-[140px] leading-none font-light opacity-95">
          {s.number}
        </div>

        <!-- huge heading -->
        <div class="absolute right-10 top-10 text-right">
          <div class="whitespace-pre-line text-[88px] leading-[0.9] font-light tracking-[0.06em]">
            {s.heading}
          </div>
        </div>

        <!-- centered body -->
        <div class="absolute inset-0 flex items-center justify-center px-6">
          <p class="max-w-xl text-center whitespace-pre-line text-[18px] leading-7 opacity-95">
            {s.body}
          </p>
        </div>
      </article>
    ))}

    <!-- Dots navigation -->
    <div class="pointer-events-auto sticky bottom-8 flex justify-center gap-3 pb-8">
      {ids.map((id, i) => (
        <a
          href={`#${id}`}
          class="h-2.5 w-2.5 rounded-full bg-white/50 hover:bg-white/90 transition"
          aria-label={`Go to value ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const scroller = document.getElementById("values-slider");
    if (!scroller) return;

    const slides = Array.from(scroller.querySelectorAll("article"));
    let locked = false;
    let wheelAcc = 0;
    let wheelTimer = null;

    const clamp = (n, min, max) => Math.max(min, Math.min(max, n));

    const index = () => {
      const h = scroller.clientHeight;
      return clamp(Math.round(scroller.scrollTop / h), 0, slides.length - 1);
    };

    const go = (i) => {
      const h = scroller.clientHeight;
      locked = true;
      scroller.scrollTo({ top: clamp(i, 0, slides.length - 1) * h, behavior: "smooth" });
      // cooldown: enough to finish smooth animation
      window.setTimeout(() => { locked = false; }, 700);
    };

    // Mouse wheel: accumulate deltas then trigger ONE slide change
    scroller.addEventListener("wheel", (e) => {
      if (locked) { e.preventDefault(); return; }

      // prevent native snap “fight”
      e.preventDefault();

      wheelAcc += e.deltaY;

      // debounce small bursts from wheel
      if (wheelTimer) window.clearTimeout(wheelTimer);
      wheelTimer = window.setTimeout(() => {
        const threshold = 120; // tuned for mouse wheel on mac
        if (Math.abs(wheelAcc) >= threshold) {
          go(index() + (wheelAcc > 0 ? 1 : -1));
        }
        wheelAcc = 0;
      }, 60);
    }, { passive: false });

    // Keyboard
    window.addEventListener("keydown", (e) => {
      const t = e.target;
      if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable)) return;

      if (e.key === "ArrowDown" || e.key === "PageDown") { e.preventDefault(); go(index() + 1); }
      if (e.key === "ArrowUp" || e.key === "PageUp") { e.preventDefault(); go(index() - 1); }
    }, { passive: false });
  })();
</script>

<style>
  #values-slider::-webkit-scrollbar { display: none; }
</style>