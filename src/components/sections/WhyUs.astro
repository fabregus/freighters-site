---
type Feature = {
  title: string;
  description: string;
  icon: string;
};

const {
  title = "Why Us?",
  features = [
    {
      title: "Global Reach",
      description:
        "Leverage our extensive international network to transport cargo swiftly and efficiently, reducing transit times and delays across more than 80 countries on six continents.",
      icon: "globe",
    },
    {
      title: "End-to-End Logistics",
      description:
        "Seamlessly combine air freight with road, rail, and ocean transport to create a flexible, fully integrated logistics strategy that adapts as your business evolves.",
      icon: "chart",
    },
    {
      title: "Sensitive Shipments",
      description:
        "Benefit from specialised handling, including temperature-controlled and secure solutions for high-value, delicate, and perishable cargo, ensuring maximum care at every stage.",
      icon: "stars",
    },
    {
      title: "Cargo Visibility",
      description:
        "Monitor your shipments in real time through our integrated control tower system, providing complete transparency, security, and confidence from origin to destination.",
      icon: "target",
    },
  ] satisfies Feature[],
} = Astro.props;
---

<section class="w-full bg-neutral-400 py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2
      class="text-center text-3xl lg:text-4xl font-light uppercase tracking-[0.3em] text-white mb-16"
      data-reveal
      style="--delay: 0ms"
    >
      {title}
    </h2>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-14 text-center text-white"
    >
      {
        features.map((feature, idx) => (
          <div
            class="flex flex-col items-center"
            data-reveal
            style={`--delay: ${120 + idx * 120}ms`}
          >
            <div class="w-20 h-20 border border-white rounded-full flex items-center justify-center mb-8">
              {feature.icon === "globe" && (
                <svg
                  class="w-8 h-8 stroke-white"
                  fill="none"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <circle cx="12" cy="12" r="9" />
                  <path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18" />
                </svg>
              )}
              {feature.icon === "chart" && (
                <svg
                  class="w-8 h-8 stroke-white"
                  fill="none"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <path d="M4 19V5" />
                  <path d="M8 19v-6" />
                  <path d="M12 19v-9" />
                  <path d="M16 19v-12" />
                  <path d="M20 19H4" />
                </svg>
              )}
              {feature.icon === "stars" && (
                <svg
                  class="w-8 h-8 stroke-white"
                  fill="none"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <path d="M12 3l1.2 3.7H17l-3 2.2 1.1 3.6-3-2.2-3 2.2 1.1-3.6-3-2.2h3.8L12 3z" />
                  <path d="M5 13l.7 2.1H8l-1.8 1.3.7 2.1-1.8-1.3-1.8 1.3.7-2.1L2 15.1h2.3L5 13z" />
                  <path d="M19 13l.7 2.1H22l-1.8 1.3.7 2.1-1.8-1.3-1.8 1.3.7-2.1-1.8-1.3h2.3L19 13z" />
                </svg>
              )}
              {feature.icon === "target" && (
                <svg
                  class="w-8 h-8 stroke-white"
                  fill="none"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <circle cx="12" cy="12" r="8" />
                  <circle cx="12" cy="12" r="4" />
                  <path d="M12 2v3M22 12h-3M12 22v-3M2 12h3" />
                </svg>
              )}
            </div>

            <h3 class="text-xl font-light mb-4">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-neutral-200">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Reveal styles scoped to this component -->
  <style>
    [data-reveal] {
      opacity: 0;
      transform: translateY(14px);
      transition:
        opacity 700ms ease,
        transform 700ms ease;
      transition-delay: var(--delay, 0ms);
      will-change: opacity, transform;
    }

    [data-reveal].is-revealed {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <!-- Init observer -->
  <script>
    import { initRevealOnScroll } from "../../scripts/reveal-on-scroll";
    initRevealOnScroll();
  </script>
</section>
