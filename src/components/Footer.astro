---
// src/components/Footer.astro

// TODO: Replace with real values / links
const phone = "+30 2100000";
const email = "info@freighters.com";

const socials = {
  instagram: "#",
  facebook: "#",
  youtube: "#",
  linkedin: "#",
};
---

<footer class="relative overflow-hidden bg-[#061A2A] text-white">
  <div class="container-site relative pt-20 pb-28">
    <div class="grid gap-12 md:grid-cols-2">
      <!-- Left column -->
      <div class="space-y-10">
        <div>
          <p class="text-sm text-white/70">Call us</p>
          <a
            href={`tel:${phone.replace(/\s+/g, "")}`}
            class="mt-1 inline-block text-lg text-white/95 hover:text-white transition"
          >
            {phone}
          </a>
        </div>

        <div>
          <p class="text-sm text-white/70">Email us</p>
          <a
            href={`mailto:${email}`}
            class="mt-1 inline-block text-lg text-white/95 hover:text-white transition"
          >
            {email}
          </a>
        </div>

        <div>
          <p class="mb-4 text-sm text-white/70">Get Social</p>

          <div class="flex items-center gap-8">
            <!-- Instagram -->
            <a
              href={socials.instagram}
              class="text-white/85 hover:text-white transition"
              aria-label="Instagram"
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Z"
                  stroke="currentColor"
                  stroke-width="1.6"></path>
                <path
                  d="M12 16.2a4.2 4.2 0 1 0 0-8.4 4.2 4.2 0 0 0 0 8.4Z"
                  stroke="currentColor"
                  stroke-width="1.6"></path>
                <path
                  d="M17.4 6.6h.01"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"></path>
              </svg>
            </a>

            <!-- Facebook -->
            <a
              href={socials.facebook}
              class="text-white/85 hover:text-white transition"
              aria-label="Facebook"
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M14 8.7V7.2c0-.7.5-1.2 1.2-1.2H17V3h-2.4C12.3 3 11 4.3 11 6.6v2.1H9v3h2V21h3v-9.3h2.5l.5-3H14Z"
                  fill="currentColor"></path>
              </svg>
            </a>

            <!-- YouTube -->
            <a
              href={socials.youtube}
              class="text-white/85 hover:text-white transition"
              aria-label="YouTube"
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M21.7 8.2a3.1 3.1 0 0 0-2.2-2.2C17.7 5.5 12 5.5 12 5.5s-5.7 0-7.5.5A3.1 3.1 0 0 0 2.3 8.2 32.4 32.4 0 0 0 2 12c0 1.3.1 2.6.3 3.8a3.1 3.1 0 0 0 2.2 2.2c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a3.1 3.1 0 0 0 2.2-2.2c.2-1.2.3-2.5.3-3.8 0-1.3-.1-2.6-.3-3.8Z"
                  stroke="currentColor"
                  stroke-width="1.6"></path>
                <path d="M10.2 9.7v4.6L14.4 12l-4.2-2.3Z" fill="currentColor"
                ></path>
              </svg>
            </a>

            <!-- LinkedIn -->
            <a
              href={socials.linkedin}
              class="text-white/85 hover:text-white transition"
              aria-label="LinkedIn"
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M6.6 6.9a1.9 1.9 0 1 0 0-3.8 1.9 1.9 0 0 0 0 3.8ZM4.8 21V9h3.6v12H4.8Z"
                  fill="currentColor"></path>
                <path
                  d="M10.2 21V9h3.4v1.7h.1c.5-1 1.7-2 3.6-2 3.8 0 4.5 2.5 4.5 5.7V21h-3.6v-5.7c0-1.4 0-3.2-2-3.2s-2.3 1.5-2.3 3.1V21h-3.7Z"
                  fill="currentColor"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right column -->
      <div class="flex items-center justify-end">
        <div
          class="text-[#F5B400] text-[72px] leading-none font-semibold tracking-tight"
        >
          freighters
        </div>
      </div>
    </div>
  </div>

  <!-- Background watermark -->
  <div
    class="pointer-events-none absolute -bottom-24 left-1/2 -translate-x-1/2 select-none"
  >
    <span
      class="text-[#F5B400] opacity-[0.1] font-bold tracking-tight text-[220px] leading-none"
    >
      freighters
    </span>
  </div>
</footer>
