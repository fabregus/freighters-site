---
const defaultNav = [
  { href: "#who-we-are", label: "Who We Are" },
  { href: "#industries", label: "Industries" },
  { href: "#solutions", label: "Solutions" },
  { href: "#contact", label: "Contact" },
];
const { nav = defaultNav } = Astro.props;
---

<header class="absolute inset-x-0 top-0 z-50">
  <div class="container-site">
    <nav class="relative flex h-20 items-center">
      <!-- left: logo -->
      <a href="/" class="shrink-0 text-[#F5B400] text-2xl font-semibold">
        freighters
      </a>

      <!-- center: desktop nav -->
      <ul class="hidden flex-1 justify-center gap-16 text-white/90 md:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="block text-sm tracking-wide hover:text-white transition"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="ml-auto flex items-center gap-4">
        <a
          href="https://portal.bluegameitsolutions.com/login"
          target="_blank"
          rel="noopener"
          class="button-primary button-primary--header inline-flex"
        >
          <img
            src="/images/bluegame-logo.png"
            alt="Bluegame"
            class="bluegame-logo"
            loading="lazy"
            decoding="async"
          />
          <span class="login-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path
                d="M14 4H8.8C7.11984 4 6.27976 4 5.63803 4.32698C5.07354 4.6146 4.6146 5.07354 4.32698 5.63803C4 6.27976 4 7.11984 4 8.8V15.2C4 16.8802 4 17.7202 4.32698 18.362C4.6146 18.9265 5.07354 19.3854 5.63803 19.673C6.27976 20 7.11984 20 8.8 20H14"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
              <path
                d="M10 12H20M20 12L17 9M20 12L17 15"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </span>
        </a>

        <!-- mobile menu button -->
        <button
          class="md:hidden inline-flex h-10 w-10 items-center justify-center text-white/90 hover:text-white transition"
          aria-label="Open menu"
          data-menu-open
        >
          <svg
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M4 7h16M4 12h16M4 17h16"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- mobile drawer -->
  <div class="fixed inset-0 z-50 hidden" data-menu-overlay aria-hidden="true">
    <!-- backdrop -->
    <div class="absolute inset-0 bg-black/50" data-menu-close></div>

    <!-- panel -->
    <div
      class="absolute right-0 top-0 h-full w-[88%] max-w-sm bg-[#061A2A] p-6"
    >
      <div class="flex items-center justify-between">
        <a href="/" class="text-[#F5B400] text-2xl font-semibold">
          freighters
        </a>

        <button
          class="inline-flex h-10 w-10 items-center justify-center text-white/90 hover:text-white transition"
          aria-label="Close menu"
          data-menu-close
        >
          <svg
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M6 6l12 12M18 6L6 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>

      <ul class="mt-10 space-y-6">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="block text-white/90 hover:text-white transition text-lg"
                data-menu-link
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <a
        href="https://portal.bluegameitsolutions.com/login"
        target="_blank"
        rel="noopener"
        class="button-primary mt-10 inline-flex"
      >
        <img
          src="/images/bluegame-logo.png"
          alt="Bluegame"
          class="bluegame-logo"
          loading="lazy"
          decoding="async"
        />
        <span class="login-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path
              d="M14 4H8.8C7.11984 4 6.27976 4 5.63803 4.32698C5.07354 4.6146 4.6146 5.07354 4.32698 5.63803C4 6.27976 4 7.11984 4 8.8V15.2C4 16.8802 4 17.7202 4.32698 18.362C4.6146 18.9265 5.07354 19.3854 5.63803 19.673C6.27976 20 7.11984 20 8.8 20H14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M10 12H20M20 12L17 9M20 12L17 15"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </span>
      </a>
    </div>
  </div>

  <!-- tiny JS (no framework) -->
  <script is:inline>
    const openBtn = document.querySelector("[data-menu-open]");
    const overlay = document.querySelector("[data-menu-overlay]");
    const closeEls = document.querySelectorAll("[data-menu-close]");
    const links = document.querySelectorAll("[data-menu-link]");

    function openMenu() {
      overlay?.classList.remove("hidden");
      document.documentElement.style.overflow = "hidden";
    }

    function closeMenu() {
      overlay?.classList.add("hidden");
      document.documentElement.style.overflow = "";
    }

    openBtn?.addEventListener("click", openMenu);
    closeEls?.forEach((el) => el.addEventListener("click", closeMenu));
    links?.forEach((a) => a.addEventListener("click", closeMenu));

    // escape to close
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });
  </script>
</header>

<style>
  .button-primary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #172654 0%, #121f48 100%);
    padding: 0.62rem 0.95rem;
    justify-content: center;
    text-decoration: none;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    cursor: pointer;
    transition: box-shadow 180ms ease, filter 180ms ease;
    box-shadow:
      0 12px 34px rgba(8, 16, 44, 0.28),
      inset 0 -2px 0 rgba(7, 15, 40, 0.65),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    width: 170px;
    z-index: 0;
  }

  .button-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      110deg,
      transparent 0%,
      transparent 35%,
      rgba(255, 255, 255, 0.28) 50%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-130%);
    opacity: 0;
    transition: transform 620ms ease, opacity 620ms ease;
    pointer-events: none;
  }

  .button-primary::after {
    content: "";
    position: absolute;
    inset: -30% -10%;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at center,
      rgba(138, 181, 255, 0.38) 0%,
      rgba(138, 181, 255, 0) 65%
    );
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 260ms ease, transform 260ms ease;
    pointer-events: none;
  }

  .button-primary:hover {
    box-shadow:
      0 16px 34px rgba(9, 23, 66, 0.4),
      inset 0 -2px 0 rgba(7, 15, 40, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    filter: brightness(1.08);
  }

  .button-primary:hover::before {
    transform: translateX(130%);
    opacity: 1;
  }

  .button-primary:hover::after {
    opacity: 0.55;
    transform: scale(1);
  }

  .bluegame-logo {
    position: relative;
    z-index: 2;
    width: 82px;
    height: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .login-icon {
    position: relative;
    z-index: 2;
    color: #ffffff;
  }

  .login-icon svg {
    width: 1.05rem;
    height: 1.05rem;
    display: block;
    transition: transform 200ms ease;
  }

  .button-primary:hover .login-icon svg {
    transform: translateX(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .button-primary::before,
    .button-primary::after,
    .button-primary {
      animation: none !important;
      transition: none !important;
      box-shadow: none !important;
    }

    .button-primary:hover .login-icon svg {
      transform: none;
    }
  }

  @media (max-width: 767px) {
    .button-primary--header {
      width: 138px;
      padding: 0.5rem 0.72rem;
      gap: 0.55rem;
    }

    .button-primary--header .bluegame-logo {
      width: 68px;
    }

    .button-primary--header .login-icon svg {
      width: 0.9rem;
      height: 0.9rem;
    }
  }
</style>
