---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/sections/Hero.astro";
import Intro from "../components/sections/Intro.astro";
import WhoWeAre from "../components/sections/WhoWeAre.astro";
import BigStatement from "../components/sections/BigStatement.astro";
import ValuesSliderGSAP from "../components/sections/ValuesSliderGSAP.astro";
import Services from "../components/sections/ServicesGrid.astro";
import Footer from "../components/Footer.astro";
---

<Layout lang="en">
  <Header lang="en" currentPath="/" />
  <Hero />
  <Intro
    titleTop="YOUR TRADE."
    titleBottom="OUR RESPONSIBILITY."
    p1="At Freighters, we combine advanced logistics planning with a strong international network to deliver reliable freight solutions across borders."
    p2="Every shipment is handled with care, transparency, and speed."
  />
  <WhoWeAre
    p1="Freighters is a modern trading and logistics company built to support businesses in a fast-moving global market."
    p2="With deep industry knowledge and a network of trusted partners, we provide smart freight solutions that combine reliability, flexibility, and transparency."
  />
  <BigStatement text="At Freighters, we go beyond transportation." />
  <ValuesSliderGSAP />
  <Services />
  <Footer />
</Layout>
