---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/sections/Hero.astro";
import Intro from "../components/sections/Intro.astro";
import BigStatement from "../components/sections/BigStatement.astro";
import Bluegame from "../components/sections/Bluegame.astro";
import CtaHero from "../components/sections/CtaHero.astro";
import IndustriesSliderGSAP from "../components/sections/IndustriesSliderGSAP.astro";
import Solutions from "../components/sections/SolutionsGrid.astro";
import WhyUs from "../components/sections/WhyUs.astro";
import ContactDetails from "../components/sections/ContactDetails.astro";
import Footer from "../components/Footer.astro";
---

<Layout lang="en">
  <Header lang="en" currentPath="/" />
  <Hero />
  <Intro
    titleTop="WHO WE ARE"
    paragraphs={[
      "Freighters is a modern trading and logistics company built to support businesses in a fast-moving global market. With deep industry knowledge and a network of trusted partners, we provide smart freight solutions that combine reliability, flexibility, and transparency.",
      "At Freighters, we combine advanced logistics planning with a strong international network to deliver reliable freight solutions across borders. Every shipment is handled with care, transparency, and speed.",
    ]}
  />
  <BigStatement text="At Freighters, we go beyond transportation." />
  <Bluegame />
  <CtaHero />
  <IndustriesSliderGSAP />
  <Solutions />
  <WhyUs />
  <ContactDetails />
  <Footer />
</Layout>
