---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/sections/Hero.astro";
import Intro from "../../components/sections/Intro.astro";
import OurPeople from "../../components/sections/OurPeople.astro";
import WhyUs from "../../components/sections/WhyUs.astro";
import CtaHero from "../../components/sections/CtaHero.astro";
import Footer from "../../components/Footer.astro";
---

<Layout lang="el" title="Σχετικά | Freighters">
  <Header />
  <Hero
    videoSrc="/video/about_hero.mp4"
    titleLeft="Freighters."
    titleRight="Με Ανθρώπους Πρώτα"
  />
  <Intro
    titleTop="ΟΛΑ ΑΡΧΙΖΟΥΝ"
    titleBottom="ΑΠΟ ΤΟΥΣ ΑΝΘΡΩΠΟΥΣ"
    p1="Η επιχείρησή σας είναι μοναδική και οι ανάγκες σας ξεχωριστές. Ακούμε, ανταποκρινόμαστε άμεσα και παραδίδουμε λύσεις σχεδιασμένες γύρω από εσάς."
  />
  <OurPeople
    image="/images/our-people.png"
    title="ΟΙ ΑΝΘΡΩΠΟΙ ΜΑΣ"
    lead="Η Freighters είναι μια σύγχρονη εμπορική και logistics εταιρεία, σχεδιασμένη να στηρίζει επιχειρήσεις σε μια παγκόσμια αγορά που κινείται γρήγορα."
    body="Οι άνθρωποί μας βρίσκονται στην καρδιά όλων όσων κάνουμε, υποστηρίζοντας την ομαλή ροή του παγκόσμιου εμπορίου. Καλλιεργούμε ένα υποστηρικτικό και συμπεριληπτικό περιβάλλον εργασίας που εκτιμά τις διαφορετικές οπτικές και επενδύει στη συνεχή εξέλιξη."
  />
  <WhyUs
    title="Γιατί Εμάς;"
    features={[
      {
        title: "Παγκόσμια Κάλυψη",
        description:
          "Αξιοποιήστε το εκτεταμένο διεθνές δίκτυό μας για γρήγορη και αποδοτική μεταφορά φορτίων, με μικρότερους χρόνους διέλευσης και λιγότερες καθυστερήσεις σε περισσότερες από 80 χώρες.",
        icon: "globe",
      },
      {
        title: "Ολοκληρωμένα Logistics",
        description:
          "Συνδυάζουμε αεροπορικές, οδικές, σιδηροδρομικές και θαλάσσιες μεταφορές σε μια ευέλικτη, πλήρως ενοποιημένη στρατηγική logistics που εξελίσσεται μαζί με την επιχείρησή σας.",
        icon: "chart",
      },
      {
        title: "Ευαίσθητα Φορτία",
        description:
          "Επωφεληθείτε από εξειδικευμένο χειρισμό, με λύσεις ελεγχόμενης θερμοκρασίας και αυξημένης ασφάλειας για υψηλής αξίας, ευπαθή και ευαίσθητα φορτία.",
        icon: "stars",
      },
      {
        title: "Ορατότητα Φορτίου",
        description:
          "Παρακολουθήστε τις αποστολές σας σε πραγματικό χρόνο μέσω του ενιαίου control tower μας, με πλήρη διαφάνεια και σιγουριά από την αφετηρία έως τον προορισμό.",
        icon: "target",
      },
    ]}
  />
  <div class="mt-100"></div>
  <CtaHero
    image="/images/services/rail-freight.jpg"
    title="ΕΞΑΣΦΑΛΙΣΤΕ ΜΙΑ ΛΥΣΗ FREIGHT FORWARDING ΠΟΥ ΤΑΙΡΙΑΖΕΙ ΑΚΡΙΒΩΣ ΣΤΙΣ ΑΝΑΓΚΕΣ ΣΑΣ."
    buttonText="Επικοινωνήστε"
    buttonLink="/el/contact"
  />
  <Footer />
</Layout>
